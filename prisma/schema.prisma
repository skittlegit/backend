generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         String   @default("agent") @db.VarChar(10)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  boards        Board[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  token     String   @unique @db.VarChar(512)
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Store {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(200)
  area       String?  @db.VarChar(200)
  status     String   @default("pending") @db.VarChar(20)
  boardCount Int      @default(0) @map("board_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  boards Board[]

  @@map("stores")
}

model Board {
  id             String   @id @default(uuid()) @db.Uuid
  storeId        String   @map("store_id") @db.Uuid
  agentId        String   @map("agent_id") @db.Uuid
  storeName      String   @map("store_name") @db.VarChar(200)
  phone          String   @db.VarChar(15)
  gstIn          String?  @map("gst_in") @db.VarChar(15)
  boardType      String   @map("board_type") @db.VarChar(20)
  boardTypeLabel String?  @map("board_type_label") @db.VarChar(100)
  widthInches    Float    @map("width_inches")
  heightInches   Float    @map("height_inches")
  latitude       Float
  longitude      Float
  photoUrl       String   @map("photo_url") @db.VarChar(1000)
  photoPath      String?  @map("photo_path") @db.VarChar(500)
  rectX          Float    @map("rect_x")
  rectY          Float    @map("rect_y")
  rectW          Float    @map("rect_w")
  rectH          Float    @map("rect_h")
  notes          String?  @db.VarChar(1000)
  submittedAt    DateTime @default(now()) @map("submitted_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  agent User  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("boards")
}
